{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "finos:rewards/CardLineup/1.0.0",
  "title": "CardLineup",
  "description": "A user's cards with earn rules, fees, limits, and perks. Provided by Module 1. All money fields are integer minor units; multiplier_rate is a decimal string.",
  "type": "object",
  "additionalProperties": false,
  "required": ["profile_id", "cards"],
  "properties": {
    "profile_id": { "type": "string", "format": "uuid" },
    "cards": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["card_id", "issuer", "product_name_en", "product_name_fr", "earn_rules", "annual_fee_cents", "credit_limit_cents", "freshness"],
        "properties": {
          "card_id": { "type": "string", "format": "uuid" },
          "issuer": { "type": "string", "minLength": 1 },
          "product_name_en": { "type": "string", "minLength": 1 },
          "product_name_fr": { "type": "string", "minLength": 1 },
          "earn_rules": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["category", "multiplier_rate"],
              "properties": {
                "category": { "type": "string", "minLength": 1 },
                "multiplier_rate": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?$" },
                "cap_cents": { "type": "integer", "minimum": 0 }
              }
            }
          },
          "annual_fee_cents": { "type": "integer", "minimum": 0 },
          "credit_limit_cents": { "type": "integer", "minimum": 0 },
          "perks": { "type": "array", "items": { "type": "object" } },
          "freshness": { "$ref": "finos:common/FreshnessStamp/1.0.0" }
        }
      }
    }
  }
}
